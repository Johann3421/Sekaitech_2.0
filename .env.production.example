# ═══════════════════════════════════════════════════════════════
#  Hyper-Logic – Production Environment Variables
#  Copy this file to .env, fill in the values, and NEVER commit it.
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
# These variables are used by the 'db' service in docker-compose.
# The DATABASE_URL for the 'app' service is built automatically
# from these same values (see docker-compose.yml).
POSTGRES_DB=hyperlogic
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── NextAuth ─────────────────────────────────────────────────
# NEXTAUTH_URL must match the exact public URL of your app.
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=https://shop.example.com
NEXTAUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# ── App public URL (built INTO the bundle – must match NEXTAUTH_URL) ──
NEXT_PUBLIC_APP_URL=https://shop.example.com

# ── Store settings ─────────────────────────────────────────────
NEXT_PUBLIC_STORE_NAME=Hyper-Logic
NEXT_PUBLIC_DEFAULT_CURRENCY=PEN

# ── Google Maps embed (optional) ───────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=

# ── Cloudinary (optional – required only if using image uploads) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Host port (optional, default 3000) ────────────────────────
# Host port on the host machine that maps to container's 3000.
# Default changed to 3006 to avoid conflicts (override if needed):
# PORT=3006
